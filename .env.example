# SAP Datasphere Tenant Environment
# Copy this file to .env and fill in your values. Never commit .env to source control.

# Required
DSP_HOST=
DSP_CLIENT_ID=
DSP_CLIENT_SECRET=

# Optional — provided by your administrator if needed
DSP_AUTHORIZATION_URL=
DSP_TOKEN_URL=

# Optional — defaults shown
DSP_AUTHORIZATION_FLOW=authorization_code
DSP_BROWSER=edge

# Agent defaults
DSP_ENV_NAME=dev